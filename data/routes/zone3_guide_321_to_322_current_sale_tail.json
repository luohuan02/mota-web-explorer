    {"action": "move", "direction": "down", "label": "2F 去小偷 10", "expect": {"floor": "MT2", "x": 7, "y": 11}},
    {"action": "move", "direction": "right", "label": "2F 去小偷 11", "expect": {"floor": "MT2", "x": 8, "y": 11}},
    {"action": "move", "direction": "right", "label": "2F 过右下钢门", "expect": {"floor": "MT2", "x": 9, "y": 11}},
