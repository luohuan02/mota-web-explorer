    {"action": "move", "direction": "right", "label": "32F 去商店 3", "expect": {"floor": "MT32", "x": 8, "y": 10}},
    {"action": "move", "direction": "right", "label": "32F 去商店 4", "expect": {"floor": "MT32", "x": 9, "y": 10}},
    {"action": "move", "direction": "right", "label": "32F 打开商店", "expect": {"floor": "MT32", "x": 10, "y": 10, "ui": true}},
    {"action": "choice", "index": 1, "label": "32F 买一次攻击", "expect": {"floor": "MT32", "x": 10, "y": 10, "atk": 134, "money": 11, "ui": true}},
    {"action": "choice", "index": 3, "label": "32F 离开商店", "expect": {"floor": "MT32", "x": 10, "y": 10, "atk": 134, "def": 154, "money": 11, "yk": 1, "bk": 0, "ui": false}},
    {"action": "save_slot", "slot": 322, "label": "保存 322：当前版本卖钥匙补钱后，32F 买一次攻击"}
  ]
